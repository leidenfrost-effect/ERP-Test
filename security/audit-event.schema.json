{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/security/audit-event.schema.json",
  "title": "Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ts_ms",
    "event",
    "request_id",
    "correlation_id",
    "trace_id",
    "action",
    "resource_type",
    "actor",
    "status"
  ],
  "properties": {
    "ts_ms": {
      "type": "integer",
      "minimum": 0
    },
    "event": {
      "type": "string",
      "const": "audit"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "action": {
      "type": "string",
      "enum": ["CREATE", "UPDATE", "DELETE", "WRITE"]
    },
    "resource_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "resource_id": {
      "type": "string",
      "maxLength": 128
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    }
  }
}
