PERSON_API_DB_PATH=./build/persons.db
PERSON_API_PORT=18080
PERSON_API_CONCURRENCY=4
PERSON_API_ENV=development

# Single token mode
PERSON_API_TOKEN=change-me

# Multi token mode (comma separated)
# PERSON_API_TOKENS=ops-token,service-token,mobile-token

# Optional RBAC permission mapping
# Production mode requires one of these when token auth is enabled.
# Format:
#   PERSON_API_TOKEN_PERMISSIONS=token=perm1|perm2,token2=*
#   PERSON_API_DEFAULT_PERMISSIONS=perm1|perm2
# Example:
# PERSON_API_TOKEN_PERMISSIONS=mobile-token=auth.verify|persons.read|products.read|stock.read,ops-token=*
